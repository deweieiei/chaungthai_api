# Copy to .env and fill in real values. NEVER commit .env to git.

# === HTTP server ===
NODE_ENV=development
PORT=3001

# Comma-separated list of origins allowed via CORS (browser fetch)
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000

# === MySQL ===
DB_HOST=110.171.128.44
DB_PORT=3306
DB_USER=dew_server1
DB_PASSWORD=Dew@1234
DB_NAME=chaungthai
DB_CONNECTION_LIMIT=10

# === JWT ===
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_me_to_a_long_random_string
JWT_REFRESH_SECRET=change_me_to_a_different_long_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# === Bcrypt ===
BCRYPT_ROUNDS=12
